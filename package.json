{
	"name": "kelan-uploader",
	"version": "1.1.2",
	"description": "Resize, compress, or convert selected, pasted, dropped, and native Obsidian attachment images, upload them to your configured API, and insert the returned URL.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
	},
	"keywords": [
		"obsidian",
		"image",
		"upload",
		"compress",
		"api"
	],
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.15.17",
		"esbuild": "^0.25.5",
		"obsidian": "^1.13.1",
		"typescript": "^5.8.3"
	},
	"dependencies": {
		"@jsquash/webp": "^1.5.0"
	}
}
